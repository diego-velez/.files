# Esto es para diferenciar entre github accounts
# Necesitas usar `git@<Host>:<git repo>` como origin repo
# Tambien necesitas cambiar el local signing key
# `git config --local user.signingkey "<path>"`

# Personal account
Host github-personal
  HostName github.com
  User git
  IdentityFile ~/.ssh/github
  IdentitiesOnly yes

